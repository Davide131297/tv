# Copy this file to .env and fill in the values.
# Vars must be prefixed with EXPO_PUBLIC_ to be inlined into the app bundle
# (see https://docs.expo.dev/guides/environment-variables/).
# They end up in the client bundle, so treat them as public, not secret.

# Base URL of the Polittalk-Watcher backend.
EXPO_PUBLIC_API_BASE_URL=https://polittalk-watcher.de

# Required for politician rankings (/api/politics?type=politician-rankings).
# Use the same value as the web app's NEXT_PUBLIC_POLITICS_API_KEY (frontend/.env).
EXPO_PUBLIC_POLITICS_API_KEY=
